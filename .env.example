# Google OAuth 2.0 Credentials (Implicit Flow Client ID)
# Retrieve this from your Google Cloud Console -> Credentials
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Apps Script Web App Deployment URL
# This endpoint acts as the database proxy for Google Sheets
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your-google-apps-script-deployment-id/exec
